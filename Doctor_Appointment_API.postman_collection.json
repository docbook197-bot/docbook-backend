        {
          "name": "Complete Doctor Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "user_id",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "specialization",
                  "value": "Cardiology",
                  "type": "text"
                },
                {
                  "key": "hospital_name",
                  "value": "City Hospital",
                  "type": "text"
                },
                {
                  "key": "profile_picture",
