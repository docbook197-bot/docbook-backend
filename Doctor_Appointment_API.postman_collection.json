              "raw": "{\n  \"availability\": [\n    {\n      \"day_of_week\": \"Monday\",\n      \"start_time\": \"09:00\",\n      \"end_time\": \"17:00\",\n      \"is_available\": true\n    },\n    {\n      \"day_of_week\": \"Tuesday\",\n      \"start_time\": \"09:00\",\n      \"end_time\": \"17:00\",\n      \"is_available\": true\n    },\n    {\n      \"day_of_week\": \"Wednesday\",\n      \"start_time\": \"09:00\",\n      \"end_time\": \"13:00\",\n      \"is_available\": true\n    }\n  ]\n}"
